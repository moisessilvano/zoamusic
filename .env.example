# ============================================================
# LOUVOR.NET — Exemplo de variáveis de ambiente
# Copie para .env e preencha com suas credenciais reais.
# ============================================================

# --- Banco de Dados ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=louvor-db
DB_USER=seu-usuario
DB_PASS=sua-senha

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- PiAPI (Suno) ---
PIAPI_KEY=00246406a2ea2576022fae16d815698a7f6f0540aec2b1a0624331f142b64440
PIAPI_BASE_URL=https://api.piapi.ai/api/suno/v1

# --- Asaas (PIX) ---
ASAAS_API_KEY=$aact_...
ASAAS_ENV=sandbox
ASAAS_SANDBOX_URL=https://api-sandbox.asaas.com/v3
ASAAS_PROD_URL=https://api.asaas.com/api/v3

# --- App ---
BASE_URL=http://localhost/sass-gospel
MUSICA_PRICE=19.90
MUSICA_DESCRIPTION=LOUVOR.NET - Música Cristã Personalizada
