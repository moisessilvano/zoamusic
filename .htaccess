# ============================================================
# LOUVOR.NET - Proteção de Servidor
# ============================================================

# 1. Impede a listagem de pastas
Options -Indexes

# 2. Bloqueia acesso a arquivos sensíveis
<FilesMatch "^\.env|^\.git|^\.htaccess|^CONFIG\.md|^db/|^logs/|^includes/">
    Order allow,deny
    Deny from all
</FilesMatch>

# 3. Bloqueia acesso direto a arquivos .sql e .log
<FilesMatch "\.(sql|log|ini|sh|bak)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# 4. Força HTTPS (Opcional - recomendado se o painel não fizer automático)
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# 5. Configurações de Redirecionamento do Encurtador (/s/CODIGO)
RewriteRule ^s/([a-zA-Z0-9]+)$ s/index.php?code=$1 [L,QSA]
